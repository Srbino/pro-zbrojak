# Konfigurace pro nasazení (Coolify/Docker). Zkopíruj jako `.env` a uprav.
# Lokální dvojklikový režim (start.command / start.bat) tyto proměnné nepotřebuje.

# Na jaké rozhraní a port aplikace poslouchá.
# V kontejneru MUSÍ být 0.0.0.0, aby byla dosažitelná z reverse proxy.
HOST=0.0.0.0
PORT=8080

# Neotevírat systémový prohlížeč (v kontejneru žádný není).
SHOW=false

# Kam se ukládají uživatelská data (SQLite DB + exporty).
# Namontuj sem persistentní volume, jinak se progres ztratí při redeployi.
PRO_ZBROJAK_STATE_DIR=/state

# --- Multi-user / přihlášení ---
# Podpis session cookie (app.storage.user). Nastav na náhodný dlouhý řetězec,
# ať sessions přežijí restart a login je bezpečný. Vygeneruj např.:
#   python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change-me

# Admini — čárkami oddělené e-maily. Vidí /admin přehled všech uživatelů.
# Identita běžně přichází z Cloudflare Access hlavičky Cf-Access-Authenticated-User-Email.
PRO_ZBROJAK_ADMINS=srba@unify.cz

# Volitelný sdílený kód pro fallback LAN login (kde Access hlavička není).
# Prázdný = LAN login bez kódu (důvěryhodná domácí síť).
PRO_ZBROJAK_LOGIN_CODE=
