# Konfigurace pro nasazení (Coolify/Docker). Zkopíruj jako `.env` a uprav.
# Lokální dvojklikový režim (start.command / start.bat) tyto proměnné nepotřebuje.

# Na jaké rozhraní a port aplikace poslouchá.
# V kontejneru MUSÍ být 0.0.0.0, aby byla dosažitelná z reverse proxy.
HOST=0.0.0.0
PORT=8080

# Neotevírat systémový prohlížeč (v kontejneru žádný není).
SHOW=false

# Kam se ukládají uživatelská data (SQLite DB + exporty).
# Namontuj sem persistentní volume, jinak se progres ztratí při redeployi.
PRO_ZBROJAK_STATE_DIR=/state
